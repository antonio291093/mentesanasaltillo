# Copy this file to .env.{env} (e.g., .env.local, .env.dev)
# and fill in the values for your environment.
#
# Select the active environment with: TEST_ENV=local npx playwright test

BASE_URL=http://localhost:3000

# Psicólogo de prueba — usado por auth.setup.ts y chromium:smoke-psicologo
LOGIN_EMAIL=psicologo@test.com
LOGIN_PASSWORD=your-psicologo-password
AUTH_FILE=e2e/.auth/psicologo.json

# Admin — usado por admin.setup.ts y chromium:smoke-admin
ADMIN_EMAIL=admin@tu-dominio.com
ADMIN_PASSWORD=your-admin-password
ADMIN_AUTH_FILE=e2e/.auth/admin.json
