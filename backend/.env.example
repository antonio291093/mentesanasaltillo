# ── Base de datos PostgreSQL ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=salud_mental_saltillo
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ── JWT ────────────────────────────────────────────────────────────────────────
# Genera un secreto seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend (para CORS) ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
