# ── Base de datos PostgreSQL ───────────────────────────────────────────────────
# DB_HOST siempre es "postgres" en Docker (nombre del servicio)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=saludmentalsaltillo
DB_USER=sms_user
DB_PASSWORD=cambiar_por_password_seguro

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_secreto_generado_con_crypto_randomBytes_64
JWT_EXPIRES_IN=7d

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=https://mentesanasaltillo.com
# URL pública de la API — usada por el cliente en el navegador
# Dejar vacío si el frontend usa rutas relativas (/api/...)
NEXT_PUBLIC_API_URL=https://mentesanasaltillo.com

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@mentesanasaltillo.com
